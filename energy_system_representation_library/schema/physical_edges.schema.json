{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/physical_edges.schema.json",
  "title": "Physical edges",
  "description": "Schema for shared/physical_edges.csv. Physical edges describe flow and dependency context between physical system nodes.",
  "type": "object",
  "required": [
    "edge_id",
    "from_node_id",
    "to_node_id",
    "edge_kind",
    "flow_label",
    "display_order",
    "notes"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "description": "Stable physical edge identifier."
    },
    "from_node_id": {
      "type": "string",
      "description": "Source physical node identifier."
    },
    "to_node_id": {
      "type": "string",
      "description": "Target physical node identifier."
    },
    "edge_kind": {
      "type": "string",
      "enum": [
        "prepares_export_resource_for",
        "provides_host_service_to",
        "sends_captured_co2_to",
        "supplies_energy_carrier_to",
        "supplies_intermediate_to"
      ],
      "description": "Physical relationship kind."
    },
    "flow_label": {
      "type": "string",
      "description": "Human-readable flow or service label."
    },
    "display_order": {
      "type": "integer",
      "description": "Stable ordering for navigation and documentation."
    },
    "notes": {
      "type": "string",
      "description": "Additional edge notes."
    }
  }
}
